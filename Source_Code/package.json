{
    "name": "erp-flow-studios",
    "version": "2.7.0",
    "private": true,
    "description": "ERP Flow Studios Healthcare Management System - Web Application",
    "author": {
        "name": "ERP Flow Studios",
        "email": "erpflowstudios@gmail.com",
        "url": "https://erpflowstudios.com"
    },
    "license": "LICENSED",
    "packageManager": "pnpm@10.32.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/ku28/erpflowstudios"
    },
    "main": "electron.js",
    "scripts": {
        "predev": "node tools/testEnvFull.ts",
        "dev": "next dev",
        "prebuild": "node tools/testEnvFull.ts",
        "build": "prisma generate && next build",
        "postinstall": "prisma generate",
        "vercel-build": "prisma generate && prisma db push --skip-generate --accept-data-loss && next build",
        "start": "next start",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev --name init",
        "seed": "node prisma/seed.js",
        "seed:defaults": "node prisma/seed-default-templates.js",
        "start-desktop": "electron .",
        "build-desktop": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
        "speech:server": "node services/speech/realtimeSpeechServer.js"
    },
    "build": {
        "appId": "com.erpflowstudios.desktop",
        "productName": "ERP Flow Studios",
        "icon": "icons/app.ico",
        "files": [
            "!**/*",
            "electron.js",
            "preload.js",
            "splash.html",
            "package.json",
            "icons/**/*",
            "node_modules/electron-updater/**/*",
            "node_modules/fs-extra/**/*",
            "node_modules/graceful-fs/**/*",
            "node_modules/jsonfile/**/*",
            "node_modules/universalify/**/*",
            "node_modules/js-yaml/**/*",
            "node_modules/argparse/**/*",
            "node_modules/lazy-val/**/*",
            "node_modules/lodash.escaperegexp/**/*",
            "node_modules/lodash.isequal/**/*",
            "node_modules/semver/**/*",
            "node_modules/tiny-typed-emitter/**/*",
            "node_modules/builder-util-runtime/**/*",
            "node_modules/debug/**/*",
            "node_modules/ms/**/*",
            "node_modules/sax/**/*",
            "offline/schema.sql",
            "offline/electron/**/*",
            "node_modules/better-sqlite3/**/*",
            "node_modules/bindings/**/*",
            "node_modules/prebuild-install/**/*",
            "node_modules/file-uri-to-path/**/*"
        ],
        "extraResources": [
            {
                "from": "icons",
                "to": "icons",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "splash.html",
                "to": "splash.html"
            },
            {
                "from": "public/splash-screen.png",
                "to": "public/splash-screen.png"
            },
            {
                "from": "public/favicon.png",
                "to": "public/favicon.png"
            },
            {
                "from": "public/splash-screen.mp4",
                "to": "public/splash-screen.mp4"
            }
        ],
        "directories": {
            "output": "dist"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "ku28",
                "repo": "erpflowstudios-app-builds"
            }
        ],
        "win": {
            "target": "nsis",
            "icon": "icons/app.ico",
            "signAndEditExecutable": false,
            "verifyUpdateCodeSignature": false
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "artifactName": "ERPFlowStudios-Setup.exe",
            "runAfterFinish": false,
            "include": "build/installer.nsh"
        }
    },
    "overrides": {
        "canvas": "npm:@napi-rs/canvas@^0.1.96",
        "better-sqlite3": "12.8.0"
    },
    "dependencies": {
        "@capacitor-community/speech-recognition": "^7.0.1",
        "@capacitor/android": "^8.1.0",
        "@capacitor/app": "^8.0.1",
        "@capacitor/browser": "^8.0.1",
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "@capacitor/filesystem": "^8.1.2",
        "@capacitor/ios": "^8.2.0",
        "@capacitor/local-notifications": "^8.0.2",
        "@capacitor/push-notifications": "^8.0.2",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^8.0.1",
        "@devnomic/marquee": "^1.0.3",
        "@google-cloud/speech": "^7.3.0",
        "@google-cloud/vision": "^5.3.4",
        "@google/genai": "^1.45.0",
        "@hookform/resolvers": "^5.2.2",
        "@napi-rs/canvas": "^0.1.96",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-avatar": "^1.1.10",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-toast": "^1.2.15",
        "@react-pdf/renderer": "^4.3.1",
        "@types/nodemailer": "^7.0.2",
        "@vercel/analytics": "^2.0.0",
        "@vercel/speed-insights": "^2.0.0",
        "bcryptjs": "^3.0.2",
        "better-sqlite3": "^12.8.0",
        "chart.js": "^4.5.1",
        "class-variance-authority": "^0.7.1",
        "cloudinary": "^2.8.0",
        "clsx": "^2.1.1",
        "csv-parser": "^3.2.0",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "electron-updater": "^6.6.2",
        "embla-carousel": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "firebase-admin": "^13.7.0",
        "formidable": "^3.5.4",
        "googleapis": "^144.0.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^3.0.3",
        "jspdf-autotable": "^5.0.2",
        "lucide-react": "^0.546.0",
        "next": "13.5.6",
        "next-themes": "^0.4.6",
        "node-cron": "^4.2.1",
        "nodemailer": "^7.0.9",
        "open": "^10.2.0",
        "pdf-parse": "1.1.1",
        "pdfjs-dist": "3.11.174",
        "pg": "^8.20.0",
        "prisma": "^7.5.0",
        "react": "18.2.0",
        "react-chartjs-2": "^5.3.1",
        "react-day-picker": "^9.11.1",
        "react-dom": "18.2.0",
        "react-hook-form": "^7.65.0",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "swr": "2.2.0",
        "tailwind-merge": "^3.3.1",
        "tailwindcss-animate": "^1.0.7",
        "tesseract.js": "^7.0.0",
        "twilio": "^5.10.3",
        "ws": "^8.20.0",
        "xlsx": "^0.18.5",
        "zod": "^4.1.12",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@types/formidable": "^3.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "20.5.6",
        "@types/node-cron": "^3.0.11",
        "@types/pdf-parse": "^1.1.5",
        "@types/pg": "^8.11.11",
        "@types/react": "^18.2.47",
        "@types/react-dom": "^18.3.7",
        "autoprefixer": "10.4.14",
        "baseline-browser-mapping": "^2.9.6",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "postcss": "8.4.43",
        "tailwindcss": "^3.4.7",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "overrides": {
            "canvas": "npm:@napi-rs/canvas@^0.1.96",
            "better-sqlite3": "12.8.0"
        },
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@prisma/client",
            "@prisma/engines",
            "better-sqlite3",
            "core-js",
            "electron",
            "electron-winstaller",
            "esbuild",
            "prisma",
            "protobufjs",
            "sharp",
            "tesseract.js"
        ]
    }
}
