# Database
# For local development:
# DATABASE_URL="postgresql://user:password@localhost:5432/erp_flow_studios"
#
# For Supabase (production / Vercel serverless) — IMPORTANT:
#   DATABASE_URL  → use the POOLER url (port 6543, Transaction mode) + pgbouncer flag:
#     DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL    → use the DIRECT url (port 5432, used only by `prisma migrate`):
#     DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# The code in lib/prisma.ts automatically appends connection_limit=1 and pool_timeout=20
# to avoid connection-pool exhaustion in serverless environments.

# Email Configuration
# ADMIN_EMAIL="erpflowstudios@gmail.com"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM="ERP FLOW STUDIOS <noreply@erpflowstudios.com>"

# Application
# NEXT_PUBLIC_APP_URL="https://erpflowstudios.com" # Used for links in emails and client-side API calls
# NEXT_PUBLIC_APP_NAME="ERP FLOW STUDIOS" # Used in email templates and UI

# Firebase Cloud Messaging (server-side Firebase Admin for Vercel)
# Use values from firebaseServicekey.json in your environment, but do not commit JSON keys.
# FIREBASE_PROJECT_ID="your-firebase-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration (for file uploads)
# Sign up at https://cloudinary.com/ to get these credentials
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Cron Job Security (for automated tasks)
# CRON_SECRET="generate-a-random-secret-key"

# WhatsApp API Configuration (Optional)
# Choose one of the following providers:

# Option 1: Twilio WhatsApp
# WHATSAPP_API_URL="https://api.twilio.com/2010-04-01/Accounts"
# WHATSAPP_API_KEY="your-twilio-auth-token"
# TWILIO_ACCOUNT_SID="your-account-sid"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_WHATSAPP_NUMBER="+14155238886"

# Option 2: Meta WhatsApp Business API
# WHATSAPP_API_URL="https://graph.facebook.com/v18.0/YOUR_PHONE_NUMBER_ID"
# WHATSAPP_API_KEY="your-meta-access-token"

# Option 3: Generic WhatsApp Gateway (e.g., Wati, Interakt, etc.)
# WHATSAPP_API_URL="your-whatsapp-gateway-url"
# WHATSAPP_API_KEY="your-api-key"
